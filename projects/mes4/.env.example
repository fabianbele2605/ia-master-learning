# ============ MES 4 - ENVIRONMENT VARIABLES ============

# ============ LLM CONFIG ============

# Ollama (local, recomendado)
OLLAMA_MODEL=qwen:7b
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (alternativa)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo

# ============ AGENT CONFIG ============

TEMPERATURE=0.7
MAX_ITERATIONS=10

# ============ LOGGING ============

LOG_LEVEL=INFO

# ============ ENVIRONMENT ============

ENV=development
DEBUG=true

# ============ COPIAR A .env Y LLENAR ============
# cp .env.example .env
