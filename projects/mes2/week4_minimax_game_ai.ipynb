   "source": [
    "## AI Engine: Minimax + Alpha-Beta"
   ]
  },
  {
   "cell_type": {"text/plain": "markdown"},
   "metadata": {},
   "source": []
  },
  {
   "cell_type": {"text/plain": "markdown"},
   "metadata": {},
   "source": [
    "## AI Minimax"
   ]
  },
  {
   "cell_type": {"text/plain": "markdown"},
   "metadata": {},
   "source": [
    "## Minimax"
   ]
  },
  {
   "cell_type": \"code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class TicTacToeAI(TicTacToe):\n",
    "    \"\"\"Extiende TicTacToe con Minimax + Alpha-Beta.\"\"\"\n",
    "    \n",
    "    def minimax(self, depth: int, is_maximizing: bool, alpha: int = float('-inf'), beta: int = float('inf')) -> int:\n",
    "        \"\"\"Minimax recursivo con alpha-beta pruning.\n",
    "        \n",
    "        depth: profundidad del árbol (para favorecer victorias rápidas)\n",
    "        is_maximizing: True si es turno de IA (MAX), False si rival (MIN)\n",
    "        alpha: mejor valor que MAX ha encontrado\n",
    "        beta: mejor valor que MIN ha encontrado\n",
    "        \"\"\"\n",
    "        \n",
    "        # Caso base: juego terminado\n",
    "        score = self.evaluate()\n",
    "        if score == 10:  # IA gana\n",
    "            return score - depth  # Favorecer victoria rápida\n",
    "        elif score == -10:  # Rival gana\n",
    "            return score + depth  # Posponer derrota\n",
    "        elif len(self.get_available_moves()) == 0:  # Empate\n",
    "            return 0\n",
    "        \n",
    "        if is_maximizing:\n",
    "            # IA intenta MAXIMIZAR el score\n",
    "            max_eval = float('-inf')\n",
    "            for move in self.get_available_moves():\n",
    "                self.make_move(move, self.ai_player)\n",
    "                eval_score = self.minimax(depth + 1, False, alpha, beta)\n",
    "                self.undo_move(move)\n",
    "                \n",
    "                max_eval = max(max_eval, eval_score)\n",
    "                alpha = max(alpha, eval_score)\n",
    "                if beta <= alpha:\n",
    "                    break  # Beta cutoff\n",
    "            \n",
    "            return max_eval\n",
    "        else:\n",
    "            # Rival intenta MINIMIZAR el score\n",
    "            min_eval = float('inf')\n",
    "            for move in self.get_available_moves():\n",
    "                self.make_move(move, self.human_player)\n",
    "                eval_score = self.minimax(depth + 1, True, alpha, beta)\n",
    "                self.undo_move(move)\n",
    "                \n",
    "                min_eval = min(min_eval, eval_score)\n",
    "                beta = min(beta, eval_score)\n",
    "                if beta <= alpha:\n",
    "                    break  # Alpha cutoff\n",
    "            \n",
    "            return min_eval\n",
    "    \n",
    "    def get_best_move(self) -> int:\n",
    "        \"\"\"Retorna el mejor movimiento para la IA.\"\"\"\n",
    "        best_score = float('-inf')\n",
    "        best_move = None\n",
    "        \n",
    "        for move in self.get_available_moves():\n",
    "            self.make_move(move, self.ai_player)\n",
    "            score = self.minimax(0, False)\n",
    "            self.undo_move(move)\n",
    "            \n",
    "            if score > best_score:\n",
    "                best_score = score\n",
    "                best_move = move\n",
    "        \n",
    "        return best_move\n",
    "\n",
    "# Test minimax\n",
    "print(\"\\n\" + \"=\"*50)\n",
    "print(\"MINIMAX DEMONSTRATION\")\n",
    "print(\"=\"*50)\n",
    "\n",
    "ai_game = TicTacToeAI()\n",
    "print(\"\\nPosición inicial:\")\n",
    "ai_game.print_board()\n",
    "\n",
    "# IA mueve primero\n",
    "best_move = ai_game.get_best_move()\n",
    "print(f\"IA elige posición: {best_move}\")\n",
    "ai_game.make_move(best_move, ai_game.ai_player)\n",
    "ai_game.print_board()\n",
    "print(\"✓ Minimax funcionando\")"
   ]
