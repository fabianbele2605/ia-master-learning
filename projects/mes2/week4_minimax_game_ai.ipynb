    "## Celda 4: Benchmarking"
   ]
  },
  {
   "cell_type": \"code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import time\n",
    "\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"BENCHMARKING: Minimax sin vs con Alpha-Beta Pruning\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Versión SIN pruning\n",
    "class TicTacToeNoPruning(TicTacToeAI):\n",
    "    def minimax_no_pruning(self, depth: int, is_maximizing: bool) -> int:\n",
    "        \"\"\"Minimax SIN alpha-beta pruning.\"\"\"\n",
    "        score = self.evaluate()\n",
    "        if score != 0:\n",
    "            return score - depth if score > 0 else score + depth\n",
    "        if len(self.get_available_moves()) == 0:\n",
    "            return 0\n",
    "        \n",
    "        best = float('-inf') if is_maximizing else float('inf')\n",
    "        for move in self.get_available_moves():\n",
    "            self.make_move(move, self.ai_player if is_maximizing else self.human_player)\n",
    "            score = self.minimax_no_pruning(depth + 1, not is_maximizing)\n",
    "            self.undo_move(move)\n",
    "            best = max(best, score) if is_maximizing else min(best, score)\n",
    "        return best\n",
    "\n",
    "# Crear posición de prueba (intermedia)\n",
    "game_pruning = TicTacToeAI()\n",
    "game_no_pruning = TicTacToeNoPruning()\n",
    "\n",
    "# Movimientos iniciales\n",
    "for move in [4, 0, 1]:  # Algunos movimientos\n",
    "    game_pruning.make_move(move, game_pruning.ai_player if move == 1 else game_pruning.human_player)\n",
    "    game_no_pruning.make_move(move, game_no_pruning.ai_player if move == 1 else game_no_pruning.human_player)\n",
    "\n",
    "# Benchmark con pruning\n",
    "start = time.time()\n",
    "best = game_pruning.get_best_move()\n",
    "time_with_pruning = time.time() - start\n",
    "\n",
    "# Benchmark sin pruning\n",
    "start = time.time()\n",
    "best_no = game_no_pruning.minimax_no_pruning(0, True)\n",
    "time_without_pruning = time.time() - start\n",
    "\n",
    "print(f\"\\nCON Alpha-Beta Pruning:    {time_with_pruning:.4f}s\")\n",
    "print(f\"SIN Alpha-Beta Pruning:    {time_without_pruning:.4f}s\")\nprint(f\"\\nAceleración: {time_without_pruning / time_with_pruning:.1f}x más rápido con pruning\")\n",
    "\n",
    "print(\"\\n📌 Conclusión:\")\n",
    "print(\"Alpha-Beta Pruning reduce exponencialmente nodos evaluados.\")\n",
    "print(f\"En este caso: {time_without_pruning / time_with_pruning:.0f}x más rápido.\")\n",
    "print(\"\\nTeoria: O(b^d) → O(b^(d/2)) con pruning perfecto\")"
   ]
