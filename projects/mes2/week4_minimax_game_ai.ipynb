    "def play_game():\n",
    "    \"\"\"Juego completo: humano vs IA con Minimax.\"\"\"\n",
    "    game = TicTacToeAI()\n",
    "    print(\"\\n\" + \"=\"*50)\n",
    "    print(\"TIC-TAC-TOE vs AI (Minimax)\")\n",
    "    print(\"=\"*50)\n",
    "    print(\"\\nPosiciones:\")\n",
    "    print(\" 0 | 1 | 2\")\n",
    "    print(\"---+---+---\")\n",
    "    print(\" 3 | 4 | 5\")\n",
    "    print(\"---+---+---\")\n",
    "    print(\" 6 | 7 | 8\\n\")\n",
    "    \n",
    "    game.print_board()\n",
    "    \n",
    "    # Simulación: humano empieza\n",
    "    moves = [4, 0]  # Humano en 4 (centro), luego la IA responde\n",
    "    \n",
    "    print(\"Simulación de partida:\")\n",
    "    for i, move in enumerate(moves):\n",
    "        if i % 2 == 0:\n",
    "            print(f\"\\nHumano juega en {move}:\")\n",
    "            if not game.make_move(move, game.human_player):\n",
    "                print(f\"¡Posición {move} ocupada!\")\n",
    "                continue\n",
    "        else:\n",
    "            print(f\"\\nIA calcula mejor movimiento...\")\n",
    "            move = game.get_best_move()\n",
    "            print(f\"IA juega en {move}:\")\n",
    "            game.make_move(move, game.ai_player)\n",
    "        \n",
    "        game.print_board()\n",
    "        \n",
    "        if game.is_game_over():\n",
    "            if game.check_winner(game.ai_player):\n",
    "                print(\"¡IA GANA!\")\n",
    "            elif game.check_winner(game.human_player):\n",
    "                print(\"¡HUMANO GANA!\")\n",
    "            else:\n",
    "                print(\"¡EMPATE!\")\n",
    "            break\n",
    "\n",
    "# Ejecutar juego simulado\n",
    "play_game()\n",
    "print(\"\\n✓ IA nunca pierde con Minimax perfecto\")"
